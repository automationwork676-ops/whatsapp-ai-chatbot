    {
      "parameters": {
        "jsCode": "const webhookData = $('Receive Whatsapp Message').item.json;\n\n// Twilio sends data either nested under 'body' or at root level\nconst body = webhookData.body || webhookData;\n\nconst incomingMessage = body.Body;\nconst fromNumber = body.From;\nconst toNumber = body.To;\n\n// Ensure + is present in the from number\nconst fixedFrom = fromNumber && !fromNumber.includes(':+') \n  ? fromNumber.replace('whatsapp:', 'whatsapp:+') \n  : fromNumber;\n\nreturn [{\n  json: {\n    message: incomingMessage,\n    from: fixedFrom,\n    to: toNumber\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
