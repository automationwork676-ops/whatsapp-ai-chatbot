        "jsCode": "const reply = $('Generate AI Reply(Gemini)').item.json.candidates[0].content.parts[0].text;\nconst from = $('Extract Message Data').item.json.from;\nconst to = $('Extract Message Data').item.json.to;\n\nreturn [{\n  json: {\n    reply: reply.trim(),\n    from: from,\n    to: to\n  }\n}];"
